const footerLinks = [
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Podcast', href: '/podcast' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <!-- Logo + tagline -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Beehive Book Marketing">
        <img
          src="/images/logo-nav.png"
          srcset="/images/logo-nav.png 1x, /images/logo-nav@2x.png 2x"
          alt="Beehive Agency"
          class="footer-logo-img"
          width="110"
          height="36"
          loading="lazy"
        />
      </a>
      <p class="footer-tagline">Books, marketed like products. Built to grow your business.</p>
    </div>

    <!-- Nav links -->
    <nav class="footer-nav" aria-label="Footer navigation">
      {footerLinks.map(link => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ))}
    </nav>

    <!-- Social icons -->
    <div class="footer-socials">
      {socials.map(s => (
        <a
          href={s.href}
          class="footer-social-icon"
          aria-label={s.label}
          target="_blank"
          rel="noopener noreferrer"
          set:html={s.icon}
        />
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {new Date().getFullYear()} Beehive Book Marketing. All rights reserved.</p>
      <p>Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="footer-astro-link">Astro</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1A1A1A;
    color: #fff;
    padding-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-logo {
    display: inline-flex;
    text-decoration: none;
  }

  .footer-logo-img {
    height: 36px;
    width: auto;
    display: block;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .footer-logo:hover .footer-logo-img {
    opacity: 1;
  }

  .footer-tagline {
    margin: 0;
    font-size: 0.875rem;
    color: #9CA3AF;
    max-width: 28ch;
  }

  /* Footer nav */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #D1D5DB;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: #E8A317;
  }

  /* Social icons */
  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: #9CA3AF;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .footer-social-icon:hover {
    color: #E8A317;
    border-color: #E8A317;
    background: rgba(232,163,23,0.08);
  }

  /* Bottom bar */
  .footer-bottom {
    padding: 1.25rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8125rem;
    color: #6B7280;
  }

  .footer-bottom-inner p {
    margin: 0;
  }

  .footer-astro-link {
    color: #E8A317;
    text-decoration: none;
  }

  .footer-astro-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-nav {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem 1.5rem;
    }

    .footer-socials {
      flex-direction: row;
      justify-content: center;
    }

    .footer-bottom-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
