---
// Option 2 — Results dashboard card
---

<div class="dash-wrap" aria-hidden="true">
  <div class="dash-card">
    <!-- Header -->
    <div class="dash-header">
      <span class="dash-title">Book Marketing Results</span>
      <span class="dash-live">
        <span class="dash-live-dot"></span>
        Live
      </span>
    </div>

    <!-- Metrics -->
    <div class="dash-metrics">
      <div class="dash-metric">
        <div class="dash-metric-top">
          <span class="dash-metric-label">Email subscribers</span>
          <span class="dash-metric-value">+847</span>
        </div>
        <div class="dash-bar-track">
          <div class="dash-bar" style="width: 78%"></div>
        </div>
      </div>
      <div class="dash-metric">
        <div class="dash-metric-top">
          <span class="dash-metric-label">Book sales this month</span>
          <span class="dash-metric-value">+124</span>
        </div>
        <div class="dash-bar-track">
          <div class="dash-bar" style="width: 58%"></div>
        </div>
      </div>
      <div class="dash-metric">
        <div class="dash-metric-top">
          <span class="dash-metric-label">Podcast reach</span>
          <span class="dash-metric-value">12.4k</span>
        </div>
        <div class="dash-bar-track">
          <div class="dash-bar" style="width: 91%"></div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="dash-divider"></div>

    <!-- Launch callout -->
    <div class="dash-callout">
      <div class="dash-callout-icon">📈</div>
      <div class="dash-callout-text">
        <span class="dash-callout-title">Launch week performance</span>
        <span class="dash-callout-sub">340% above pre-launch baseline</span>
      </div>
    </div>
  </div>

  <!-- Floating badge -->
  <div class="dash-badge">
    <span class="dash-badge-dot"></span>
    <span>Available for new clients</span>
  </div>
</div>

<style>
  .dash-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .dash-card {
    width: 100%;
    background: #1A1A1A;
    border-radius: 1.25rem;
    padding: 1.75rem;
    box-shadow: 0 24px 64px rgba(0,0,0,0.15), 0 0 0 1px rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Header */
  .dash-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dash-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .dash-live {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #22C55E;
    background: rgba(34,197,94,0.1);
    border: 1px solid rgba(34,197,94,0.2);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  .dash-live-dot {
    width: 6px;
    height: 6px;
    background: #22C55E;
    border-radius: 50%;
    animation: pulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Metrics */
  .dash-metrics {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .dash-metric {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .dash-metric-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dash-metric-label {
    font-size: 0.8125rem;
    color: #9CA3AF;
  }

  .dash-metric-value {
    font-size: 0.875rem;
    font-weight: 700;
    color: #E8A317;
  }

  .dash-bar-track {
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 9999px;
    overflow: hidden;
  }

  .dash-bar {
    height: 100%;
    background: linear-gradient(90deg, #E8A317, #F4C557);
    border-radius: 9999px;
  }

  /* Divider */
  .dash-divider {
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  /* Launch callout */
  .dash-callout {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    background: rgba(232,163,23,0.08);
    border: 1px solid rgba(232,163,23,0.2);
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
  }

  .dash-callout-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .dash-callout-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .dash-callout-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #E8A317;
  }

  .dash-callout-sub {
    font-size: 0.8125rem;
    color: #6B7280;
  }

  /* Floating badge */
  .dash-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #374151;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    margin-right: 1rem;
  }

  .dash-badge-dot {
    width: 8px;
    height: 8px;
    background: #22C55E;
    border-radius: 50%;
    flex-shrink: 0;
  }
</style>
