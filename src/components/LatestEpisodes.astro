---
import { getCollection } from 'astro:content';

const allEpisodes = await getCollection('podcast');
const allPosts = await getCollection('blog');

const episodes = allEpisodes
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

function youtubeId(url: string): string | undefined {
  const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([A-Za-z0-9_-]{11})/);
  return m?.[1];
}

function getYoutubeData(guid: string): { url: string; thumb: string } | undefined {
  const post = allPosts.find(p => p.data.episodeGuids.includes(guid) && p.data.youtubeUrl);
  if (!post?.data.youtubeUrl) return undefined;
  const id = youtubeId(post.data.youtubeUrl);
  if (!id) return undefined;
  return {
    url: post.data.youtubeUrl,
    thumb: `https://img.youtube.com/vi/${id}/maxresdefault.jpg`,
  };
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<section class="episodes section" id="podcast">
  <div class="container">
    <!-- Section header -->
    <div class="episodes-header">
      <div class="episodes-header-text">
        <span class="section-eyebrow">The Hive Mind</span>
        <h2 class="episodes-heading">From the Podcast</h2>
        <p class="episodes-sub">Conversations with authors, marketers, and operators on turning a book into a business asset that pays — in pipeline, deals, and stages.</p>
      </div>
      <a href="/podcast" class="episodes-see-all">
        See All Episodes <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Episode cards -->
    {episodes.length > 0 ? (
      <div class="episodes-grid">
        {episodes.map(ep => {
          const yt = getYoutubeData(ep.data.guid);
          const href = yt ? yt.url : `/podcast/#ep-${ep.data.episode}`;
          const thumb = yt?.thumb ?? ep.data.episodeImage;
          return (
            <a href={href} class="episode-card card" target={yt ? '_blank' : undefined} rel={yt ? 'noopener noreferrer' : undefined}>
              <!-- Thumbnail -->
              <div class="episode-thumb">
                {thumb ? (
                  <img src={thumb} alt="" class="episode-thumb-img" loading="lazy" />
                ) : (
                  <div class="episode-thumb-placeholder">
                    <span class="episode-thumb-num">EP {ep.data.episode}</span>
                  </div>
                )}
                <div class="episode-play-overlay" aria-hidden="true">
                  <span class="episode-play-btn">▶</span>
                </div>
              </div>

              <!-- Meta -->
              <div class="episode-meta">
                <span class="episode-num-label">Episode {ep.data.episode}</span>
                <time class="episode-date" datetime={ep.data.publishDate.toISOString()}>
                  {formatDate(ep.data.publishDate)}
                </time>
              </div>

              <h3 class="episode-title">{ep.data.title}</h3>

              {ep.data.guest && (
                <p class="episode-guest">
                  <span class="episode-guest-label">Guest:</span> {ep.data.guest}
                </p>
              )}

              <p class="episode-desc">{ep.data.summary}</p>
            </a>
          );
        })}
      </div>
    ) : (
      <p class="episodes-empty">Loading episodes…</p>
    )}

    <!-- Mobile see all -->
    <div class="episodes-mobile-cta">
      <a href="/podcast" class="btn-primary">See All Episodes →</a>
    </div>
  </div>
</section>

<style>
  .episodes {
    background: #FDF8F0;
  }

  /* Header */
  .episodes-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
    margin-bottom: 0.625rem;
  }

  .episodes-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }

  .episodes-sub {
    font-size: 1rem;
    color: #6B7280;
    margin: 0;
    max-width: 50ch;
  }

  .episodes-see-all {
    flex-shrink: 0;
    font-weight: 600;
    font-size: 0.9375rem;
    color: #E8A317;
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .episodes-see-all:hover {
    border-color: #E8A317;
  }

  /* Grid */
  .episodes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Card */
  .episode-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    color: inherit;
    background: #fff;
    overflow: hidden;
    padding: 0;
  }

  /* Thumbnail */
  .episode-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 0.75rem 0.75rem 0 0;
  }

  .episode-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #E8A317 0%, #F4C557 60%, #D4920F 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .episode-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .episode-card:hover .episode-thumb-img {
    transform: scale(1.02);
  }

  .episode-thumb-num {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .episode-play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .episode-card:hover .episode-play-overlay {
    background: rgba(0,0,0,0.2);
  }

  .episode-play-btn {
    width: 3.5rem;
    height: 3.5rem;
    background: rgba(255,255,255,0.92);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: #1A1A1A;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.2s, transform 0.2s;
    padding-left: 3px;
  }

  .episode-card:hover .episode-play-btn {
    opacity: 1;
    transform: scale(1);
  }

  /* Card content */
  .episode-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem 0;
  }

  .episode-num-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #E8A317;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .episode-date {
    font-size: 0.75rem;
    color: #9CA3AF;
  }

  .episode-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.35;
    margin: 0.625rem 1.25rem 0.5rem;
  }

  .episode-guest {
    font-size: 0.8125rem;
    color: #6B7280;
    margin: 0 1.25rem 0.625rem;
  }

  .episode-guest-label {
    font-weight: 600;
    color: #374151;
  }

  .episode-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #4B5563;
    margin: 0 1.25rem 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* Empty / mobile */
  .episodes-empty {
    text-align: center;
    color: #6B7280;
    padding: 3rem 0;
  }

  .episodes-mobile-cta {
    display: none;
    justify-content: center;
    margin-top: 2rem;
  }

  @media (max-width: 960px) {
    .episodes-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }

    .episodes-see-all {
      display: none;
    }

    .episodes-mobile-cta {
      display: flex;
    }
  }

  @media (min-width: 640px) and (max-width: 960px) {
    .episodes-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
  }
</style>
