---
import { getCollection } from 'astro:content';

interface Props {
  guid: string;
}

const { guid } = Astro.props;
const allEpisodes = await getCollection('podcast');
const allPosts = await getCollection('blog');

const ep = allEpisodes.find(e => e.data.guid === guid);
const post = allPosts.find(p => p.data.episodeGuids.includes(guid));

function youtubeId(url: string): string | undefined {
  const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([A-Za-z0-9_-]{11})/);
  return m?.[1];
}

const ytId = post?.data.youtubeUrl ? youtubeId(post.data.youtubeUrl) : undefined;
---

{ep && (
  <figure class="episode-player">
    {ytId ? (
      <div class="episode-player-video">
        <iframe
          src={`https://www.youtube.com/embed/${ytId}`}
          title={ep.data.title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    ) : (
      <div class="episode-player-meta">
        {ep.data.episodeImage && (
          <img src={ep.data.episodeImage} alt="" class="episode-player-cover" loading="lazy" />
        )}
        <div class="episode-player-info">
          <span class="episode-player-tag">Episode {ep.data.episode}{ep.data.duration ? ` · ${ep.data.duration}` : ''}</span>
          <p class="episode-player-title">{ep.data.title}</p>
        </div>
      </div>
    )}
    <figcaption class="episode-player-platforms">
      <span>Also on</span>
      <a href="https://open.spotify.com/show/033l9h1JaE3qhlslHbDS7h" target="_blank" rel="noopener">Spotify</a>
      <a href="https://podcasts.apple.com/podcast/id1896795747" target="_blank" rel="noopener">Apple Podcasts</a>
    </figcaption>
  </figure>
)}

<style>
  .episode-player {
    margin: 2rem 0;
    background: #1A1A1A;
    border-radius: 1rem;
    overflow: hidden;
    color: #fff;
  }

  .episode-player-video {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .episode-player-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* Fallback (no YouTube URL) */
  .episode-player-meta {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 0.875rem;
    align-items: center;
    padding: 1.25rem 1.25rem 0.875rem;
  }

  .episode-player-cover {
    width: 72px;
    height: 72px;
    border-radius: 0.5rem;
    object-fit: cover;
    display: block;
  }

  .episode-player-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .episode-player-tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
  }

  .episode-player-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.35;
  }

  .episode-player-platforms {
    padding: 0.75rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.75rem;
    color: #9CA3AF;
  }

  .episode-player-platforms a {
    color: #E8A317;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .episode-player-platforms a:hover {
    border-bottom-color: #E8A317;
  }
</style>
