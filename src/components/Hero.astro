---
---

<section class="hero">
  <!-- Decorative honeycomb dots -->
  <div class="hero-dots hero-dots--tl" aria-hidden="true"></div>
  <div class="hero-dots hero-dots--br" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <!-- Eyebrow -->
      <span class="hero-eyebrow">Book Marketing for Experts & Founders</span>

      <!-- Heading -->
      <h1 class="hero-heading">
        Your book, marketed like a<br />
        <em class="hero-heading-accent">SaaS product</em><br />
        — built to grow your business.
      </h1>

      <!-- Subheadline -->
      <p class="hero-sub">
        A fractional marketing partner for authors who want their book to drive more leads,
        shorten the sales cycle, and raise speaking fees — applying <strong>funnel,
        attribution, and conversion</strong> thinking from SaaS to the publishing world.
      </p>

      <!-- CTA buttons -->
      <div class="hero-buttons">
        <a href="/contact" class="btn-primary hero-btn-primary">
          Book a Discovery Call <span aria-hidden="true">→</span>
        </a>
        <a href="/webinar" class="btn-outline hero-btn-secondary">
          Join the next webinar <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Trust row -->
      <div class="hero-trust">
        <div class="hero-trust-item">
          <span class="hero-trust-dot" aria-hidden="true">●</span>
          <span>Your marketing team, on retainer</span>
        </div>
        <div class="hero-trust-item">
          <span class="hero-trust-dot" aria-hidden="true">●</span>
          <span>Measured in business results, not copies sold</span>
        </div>
        <div class="hero-trust-item">
          <span class="hero-trust-dot" aria-hidden="true">●</span>
          <span>Taking 2–3 clients at a time</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #FFFDF7 0%, #FFF8E7 40%, #FDF4DB 100%);
    padding: 6rem 0 5rem;
  }

  /* Decorative dot grids */
  .hero-dots {
    position: absolute;
    width: 280px;
    height: 280px;
    background-image: radial-gradient(circle, #E8A317 1.5px, transparent 1.5px);
    background-size: 22px 22px;
    opacity: 0.18;
    pointer-events: none;
  }

  .hero-dots--tl { top: -40px; left: -40px; }
  .hero-dots--br { bottom: -40px; right: -40px; }

  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #E8A317;
    background: rgba(232,163,23,0.1);
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: #1A1A1A;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-heading-accent {
    font-style: italic;
    color: #E8A317;
  }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #4B5563;
    max-width: 52ch;
    margin: 0 0 2rem;
  }

  .hero-sub strong {
    color: #1A1A1A;
    font-weight: 600;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 2rem;
  }

  .hero-btn-primary {
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
  }

  .hero-btn-secondary {
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
  }

  /* Trust row */
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: #6B7280;
  }

  .hero-trust-dot {
    font-size: 0.4rem;
    color: #E8A317;
  }

  @media (max-width: 540px) {
    .hero {
      padding: 4rem 0 3.5rem;
    }

    .hero-buttons {
      flex-direction: column;
    }

    .hero-btn-primary,
    .hero-btn-secondary {
      justify-content: center;
    }

    .hero-trust {
      flex-direction: column;
      gap: 0.625rem;
    }
  }
</style>
