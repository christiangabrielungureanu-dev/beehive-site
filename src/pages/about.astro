---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const siteUrl = Astro.site?.href ?? 'https://beehivebookmarketing.com/';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/about', Astro.site).href,
  name: 'Cristian Ungureanu',
  url: new URL('/about', Astro.site).href,
  image: new URL('/cristian-pic.jpg', Astro.site).href,
  jobTitle: 'Founder',
  description: 'Senior growth marketer ($5M+ ARR in B2B SaaS) and founder of Beehive Book Marketing. Helps experts and founders turn their books into lead engines.',
  sameAs: ['https://www.linkedin.com/in/cristian-ungureanu/'],
  worksFor: {
    '@type': 'Organization',
    name: 'Beehive Book Marketing',
    url: siteUrl,
  },
};
---

<BaseLayout
  title="About Cristian Ungureanu — Beehive Book Marketing"
  description="Cristian Ungureanu is a senior growth marketer ($5M+ ARR in B2B SaaS) who brings funnel-and-attribution thinking to experts and founders publishing books."
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <!-- Hero -->
  <section class="about-hero section">
    <div class="container about-hero-inner">
      <div class="about-hero-content">
        <span class="eyebrow">The Person Behind the Agency</span>
        <h1 class="about-hero-heading">
          I Spent a Decade Growing Tech Companies.<br />
          <em class="accent">Now I Do It for Books.</em>
        </h1>
        <p class="about-hero-sub">
          My name is Cristian Ungureanu. I'm a marketer, strategist, and the founder of Beehive
          Book Marketing — an agency built on one core belief: authors deserve the same
          sophisticated marketing that the best tech startups use.
        </p>
      </div>
      <div class="about-hero-photo">
        <img src="/cristian-pic.jpg" alt="Cristian Ungureanu, founder of Beehive Book Marketing" class="about-photo-img" />
        <div class="about-photo-card">
          <span class="about-photo-name">Cristian Ungureanu</span>
          <span class="about-photo-title">FOUNDER — BEEHIVE BOOK MARKETING</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Background -->
  <section class="section about-bg-section">
    <div class="container about-content-grid">
      <div class="about-sidebar">
        <div class="about-stat-stack">
          <div class="about-stat-card">
            <span class="about-stat-num">$5M+</span>
            <span class="about-stat-desc">ARR generated for tech clients</span>
          </div>
          <div class="about-stat-card">
            <span class="about-stat-num">10+</span>
            <span class="about-stat-desc">Years in growth marketing</span>
          </div>
          <div class="about-stat-card">
            <span class="about-stat-num">2</span>
            <span class="about-stat-desc">Successful SaaS marketing programs led</span>
          </div>
        </div>
      </div>

      <div class="about-body">
        <h2 class="about-section-heading">My Background</h2>
        <p>
          Before starting Beehive, I was a senior marketer in the B2B SaaS world. At
          <strong>QuickMail.io</strong>, I helped build the demand generation engine from the ground
          up — content, SEO, outbound, paid, and partnerships. At <strong>ScraperAPI.com</strong>,
          I led growth marketing strategy and helped the team scale to significant ARR.
        </p>
        <p>
          The common thread across every company I worked with: growth happens when you combine
          a clear positioning, a deep understanding of the buyer, and a distribution system that
          compounds over time. Not one-off tactics. Not vanity metrics. A machine.
        </p>
        <p>
          When I started paying attention to the book marketing industry, I was genuinely shocked
          at how far behind the playbook is. Most authors are still relying on launch-week
          Amazon ranking tricks and cold pitching journalists — while the best B2B SaaS companies
          have solved this problem years ago with content, community, and email.
        </p>
        <p>
          That gap is where Beehive lives.
        </p>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="section about-philosophy">
    <div class="container">
      <div class="about-philosophy-header">
        <span class="eyebrow">How I Think</span>
        <h2 class="about-section-heading">The Beehive Philosophy</h2>
      </div>

      <div class="philosophy-grid">
        <div class="philosophy-card">
          <span class="philosophy-icon">🎯</span>
          <h3>Positioning before tactics</h3>
          <p>
            If you don't know exactly who your book is for and why they should care, no amount of
            ad spend or PR will fix it. We start every engagement by nailing the positioning.
          </p>
        </div>
        <div class="philosophy-card">
          <span class="philosophy-icon">🌱</span>
          <h3>Compounding beats spiking</h3>
          <p>
            A launch week spike is nice. An email list that grows every month and an SEO presence
            that drives sales two years after publication — that's what we're building toward.
          </p>
        </div>
        <div class="philosophy-card">
          <span class="philosophy-icon">📊</span>
          <h3>Data-informed, not data-obsessed</h3>
          <p>
            We track what matters and ignore what doesn't. Sales, email growth, and reader
            engagement tell the real story. Amazon rank on a Tuesday does not.
          </p>
        </div>
        <div class="philosophy-card">
          <span class="philosophy-icon">🤝</span>
          <h3>Authors are partners, not clients</h3>
          <p>
            Your book is your business. We treat it that way. You'll always know what we're doing,
            why we're doing it, and what the results are.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Books -->
  <section class="section about-why">
    <div class="container about-why-inner">
      <div class="about-why-content">
        <span class="eyebrow">Why Books</span>
        <h2 class="about-section-heading">
          Why I Left Tech to Work with Authors
        </h2>
        <p>
          The honest answer: books matter in a way that SaaS products don't. A well-marketed book
          can change how someone thinks about their career, their family, their business. It can
          give an author a platform that lasts decades.
        </p>
        <p>
          But most authors — even brilliant ones, even ones with important ideas — never get that
          reach. Not because their books aren't good enough. Because nobody showed them how to
          market them.
        </p>
        <p>
          That's the problem I want to solve. I want to be the person who helps the author with
          the genuinely great book find the readers who need it.
        </p>
        <a href="/contact" class="btn-primary" style="display:inline-flex;margin-top:1.5rem;">
          Let's Talk About Your Book →
        </a>
      </div>
      <div class="about-why-quote">
        <blockquote class="about-pullquote">
          <span class="about-pullquote-mark" aria-hidden="true">&ldquo;</span>
          <p>The best book marketing doesn't feel like marketing. It feels like the right book finding the right reader at the right time.</p>
          <footer>
            <span class="about-pullquote-name">Cristian Ungureanu</span>
            <span class="about-pullquote-title">Founder, Beehive Book Marketing</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  /* Shared */
  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
    margin-bottom: 0.625rem;
  }

  .accent { font-style: italic; color: #E8A317; }

  .about-section-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.625rem, 2.5vw, 2.25rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 1.5rem;
  }

  /* Hero */
  .about-hero { background: linear-gradient(135deg, #FFFDF7 0%, #FFF8E7 100%); }

  .about-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  .about-hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0.5rem 0 1.25rem;
  }

  .about-hero-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #4B5563;
    margin: 0;
  }

  /* Photo */
  .about-hero-photo { position: relative; }

  .about-photo-placeholder {
    aspect-ratio: 4/5;
    border-radius: 1.5rem;
    background: linear-gradient(145deg, #E8A317 0%, #F4C557 50%, #D4920F 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-photo-initials {
    font-family: var(--font-heading);
    font-size: 5rem;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
  }

  .about-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1.5rem;
    display: block;
  }

  .about-photo-card {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-radius: 0.75rem;
    padding: 0.75rem 1.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    white-space: nowrap;
  }

  .about-photo-name {
    font-family: var(--font-script);
    font-size: 1.375rem;
    color: #1A1A1A;
  }

  .about-photo-title {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #E8A317;
    text-transform: uppercase;
  }

  /* Background section */
  .about-bg-section { background: #fff; }

  .about-content-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-stat-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 5.5rem;
  }

  .about-stat-card {
    background: #FFF8E7;
    border: 1px solid rgba(232,163,23,0.2);
    border-radius: 0.875rem;
    padding: 1.25rem;
  }

  .about-stat-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: #E8A317;
    margin-bottom: 0.25rem;
  }

  .about-stat-desc {
    font-size: 0.8125rem;
    color: #6B7280;
    line-height: 1.4;
  }

  .about-body p {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #374151;
    margin: 0 0 1.25rem;
  }

  .about-body strong { color: #1A1A1A; font-weight: 600; }

  /* Philosophy */
  .about-philosophy { background: #FDF8F0; }

  .about-philosophy-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .philosophy-card {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 1rem;
    padding: 1.75rem;
  }

  .philosophy-icon { font-size: 1.75rem; display: block; margin-bottom: 1rem; }

  .philosophy-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.625rem;
  }

  .philosophy-card p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #4B5563;
    margin: 0;
  }

  /* Why books */
  .about-why { background: #fff; }

  .about-why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-why-content p {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #374151;
    margin: 0 0 1.25rem;
  }

  /* Pull quote */
  .about-pullquote {
    position: relative;
    background: #1A1A1A;
    border-radius: 1.25rem;
    padding: 2.5rem 2rem 2rem;
    margin: 0;
  }

  .about-pullquote-mark {
    position: absolute;
    top: 1rem;
    left: 1.5rem;
    font-family: Georgia, serif;
    font-size: 4rem;
    color: #E8A317;
    opacity: 0.4;
    line-height: 1;
  }

  .about-pullquote p {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.6;
    color: #fff;
    margin: 0 0 1.5rem;
  }

  .about-pullquote footer {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .about-pullquote-name {
    font-family: var(--font-script);
    font-size: 1.25rem;
    color: #E8A317;
  }

  .about-pullquote-title {
    font-size: 0.75rem;
    color: #6B7280;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .about-hero-inner,
    .about-why-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-content-grid { grid-template-columns: 1fr; }
    .about-stat-stack { position: static; flex-direction: row; flex-wrap: wrap; }
    .about-stat-card { flex: 1; min-width: 140px; }
    .philosophy-grid { grid-template-columns: 1fr; }
  }
</style>
