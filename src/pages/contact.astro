---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Discovery Call — Beehive Book Marketing"
  description="Free 30-minute call with Cristian to talk about your book, your business, and whether Beehive's playbook for experts and founders is the right fit. No pitch."
>
  <section class="contact-hero section">
    <div class="container contact-hero-inner">
      <div class="contact-hero-content">
        <span class="eyebrow">Let's Connect</span>
        <h1 class="contact-heading">
          Book a Free<br />
          <em class="accent">Discovery Call</em>
        </h1>
        <p class="contact-sub">
          A free, 30-minute conversation about your book, your goals, and whether Beehive is
          the right fit. No pitch. No pressure. Just an honest conversation.
        </p>

        <div class="contact-trust">
          {[
            { icon: '🗓️', text: 'Free 30-minute call' },
            { icon: '🚫', text: 'No obligation whatsoever' },
            { icon: '📈', text: 'Honest about what will work' },
            { icon: '⏱️', text: 'Limited spots available' },
          ].map(item => (
            <div class="contact-trust-item">
              <span>{item.icon}</span>
              <span>{item.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Calendar booking -->
      <div class="calendar-card">
        <span class="calendar-icon">📅</span>
        <h2 class="calendar-heading">Pick a Time That Works</h2>
        <p class="calendar-body">
          Choose a slot directly in Cristian's calendar. You'll get a confirmation
          email with everything you need.
        </p>
        <a
          href="https://calendar.app.google/QPtb8YM4ZHUcpgaQ7"
          target="_blank"
          rel="noopener"
          class="btn-primary calendar-btn"
        >
          Open Booking Calendar →
        </a>
      </div>
    </div>
  </section>

  <!-- Contact form fallback -->
  <section class="section contact-form-section">
    <div class="container contact-form-inner">
      <div class="contact-form-header">
        <span class="eyebrow">Or Send a Message</span>
        <h2 class="contact-form-heading">Get in Touch</h2>
        <p class="contact-form-sub">Prefer to write? Fill out the form and we'll respond within one business day.</p>
      </div>

      <form class="contact-form" id="contact-form" action="https://formspree.io/f/xpqnzkrk" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="firstName" class="form-label">First name</label>
            <input type="text" id="firstName" name="firstName" class="form-input" placeholder="Jane" required />
          </div>
          <div class="form-group">
            <label for="lastName" class="form-label">Last name</label>
            <input type="text" id="lastName" name="lastName" class="form-input" placeholder="Author" />
          </div>
        </div>
        <div class="form-group">
          <label for="email" class="form-label">Email address</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="jane@example.com" required />
        </div>
        <div class="form-group">
          <label for="bookTitle" class="form-label">Book title <span class="form-optional">(optional)</span></label>
          <input type="text" id="bookTitle" name="bookTitle" class="form-input" placeholder="My Book Title" />
        </div>
        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell us about your book and what you're looking for..." rows="4" required></textarea>
        </div>
        <input type="hidden" name="_subject" value="New contact form submission — Beehive" />
        <button type="submit" class="btn-primary form-submit">Send Message →</button>
      </form>

      <div id="contact-success" class="contact-success" hidden>
        <span class="contact-success-icon">✓</span>
        <div>
          <strong>Message received!</strong>
          <p>We'll get back to you within one business day.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
    margin-bottom: 0.625rem;
  }

  .accent { font-style: italic; color: #E8A317; }

  /* Hero */
  .contact-hero { background: linear-gradient(135deg, #FFFDF7 0%, #FFF8E7 100%); }

  .contact-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0.5rem 0 1.25rem;
    line-height: 1.2;
  }

  .contact-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #4B5563;
    margin: 0 0 2rem;
  }

  .contact-trust {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-trust-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: #374151;
  }

  /* Calendar card */
  .calendar-card {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 1.25rem;
    padding: 3rem 2.5rem;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .calendar-icon { font-size: 3rem; display: block; margin-bottom: 1rem; }

  .calendar-heading {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.75rem;
  }

  .calendar-body {
    font-size: 0.9375rem;
    color: #6B7280;
    line-height: 1.6;
    margin: 0 0 1.75rem;
    max-width: 320px;
    margin-inline: auto;
    margin-bottom: 1.75rem;
  }

  .calendar-btn {
    font-size: 1rem;
    padding: 0.875rem 2rem;
  }

  /* Contact form */
  .contact-form-section { background: #fff; border-top: 1px solid #F3F4F6; }

  .contact-form-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-form-header { text-align: center; margin-bottom: 2.5rem; }

  .contact-form-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.625rem, 2.5vw, 2.125rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }

  .contact-form-sub {
    font-size: 1rem;
    color: #6B7280;
    margin: 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
  }

  .form-optional {
    font-weight: 400;
    color: #9CA3AF;
  }

  .form-input {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: #1A1A1A;
    background: #fff;
    border: 1.5px solid #E5E7EB;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    transition: border-color 0.15s;
  }

  .form-input:focus {
    outline: none;
    border-color: #E8A317;
  }

  .form-textarea { resize: vertical; min-height: 120px; }

  .form-submit { align-self: flex-start; margin-top: 0.5rem; }

  /* Success */
  .contact-success {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.25);
    border-radius: 0.75rem;
    margin-top: 1rem;
  }

  .contact-success-icon {
    width: 2rem;
    height: 2rem;
    background: #22C55E;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }

  .contact-success strong { display: block; color: #15803D; margin-bottom: 0.25rem; }
  .contact-success p { margin: 0; font-size: 0.875rem; color: #374151; }

  @media (max-width: 900px) {
    .contact-hero-inner { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('contact-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.form-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const data: Record<string, string> = {};
    new FormData(form).forEach((val, key) => { data[key] = val.toString(); });

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.hidden = true;
        successEl.hidden = false;
      } else {
        btn.disabled = false;
        btn.textContent = 'Send Message →';
        alert('Something went wrong. Please try again or email us directly.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Send Message →';
    }
  });
</script>
