---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignupForm from '../../components/SignupForm.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('podcast', ({ data }) => !data.draft);
  return episodes.map(ep => ({
    params: { slug: ep.id },
    props: { ep },
  }));
}

const { ep } = Astro.props;
const { Content } = await render(ep);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const youtubeThumb = `https://img.youtube.com/vi/${ep.data.youtubeId}/maxresdefault.jpg`;
---

<BaseLayout
  title={`${ep.data.title} — The Hive Mind`}
  description={ep.data.description}
  ogImage={youtubeThumb}
>
  <article class="episode-page">
    <!-- Episode header -->
    <header class="episode-header">
      <div class="container episode-header-inner">
        <nav class="episode-breadcrumb" aria-label="Breadcrumb">
          <a href="/podcast" class="breadcrumb-link">← All Episodes</a>
        </nav>

        <div class="episode-meta-row">
          <span class="episode-num">Episode {ep.data.episode}</span>
          <span class="episode-sep" aria-hidden="true">·</span>
          <time class="episode-date" datetime={ep.data.publishDate.toISOString()}>
            {formatDate(ep.data.publishDate)}
          </time>
        </div>

        <h1 class="episode-heading">{ep.data.title}</h1>

        <p class="episode-guest-line">
          <strong>Guest:</strong> {ep.data.guest}
          {ep.data.guestTitle && <span class="episode-guest-title"> — {ep.data.guestTitle}</span>}
        </p>

        <div class="episode-tags">
          {ep.data.tags.map(tag => (
            <span class="episode-tag">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <!-- YouTube embed -->
    <section class="episode-video-section">
      <div class="container">
        <div class="youtube-wrap">
          <!-- Lazy-loaded: shows thumbnail, loads iframe on click -->
          <div
            class="youtube-facade"
            data-videoid={ep.data.youtubeId}
            role="button"
            tabindex="0"
            aria-label={`Play: ${ep.data.title}`}
          >
            <img
              src={youtubeThumb}
              alt={`Thumbnail for ${ep.data.title}`}
              class="youtube-thumb"
            />
            <div class="youtube-play" aria-hidden="true">
              <span class="youtube-play-icon">▶</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Article body -->
    <div class="episode-body-wrap">
      <div class="container episode-body-inner">
        <div class="episode-article">
          <div class="episode-content prose">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="episode-sidebar">
          <!-- CTA: Next episode -->
          <div class="sidebar-card sidebar-card--dark">
            <h3 class="sidebar-card-heading">Catch the next one live</h3>
            <p class="sidebar-card-body">New episodes drop regularly. Sign up to get notified first.</p>
            <SignupForm
              source="episode-sidebar"
              userGroup="podcast-waitlist"
              buttonText="Notify Me →"
              placeholder="your@email.com"
              dark={true}
            />
          </div>

          <!-- Guest info -->
          <div class="sidebar-card">
            <h3 class="sidebar-card-heading sidebar-card-heading--dark">About the Guest</h3>
            <div class="sidebar-guest">
              {ep.data.guestImage ? (
                <img src={ep.data.guestImage} alt={ep.data.guest} class="sidebar-guest-img" />
              ) : (
                <div class="sidebar-guest-avatar">
                  {ep.data.guest.split(' ').map(w => w[0]).slice(0, 2).join('')}
                </div>
              )}
              <div>
                <p class="sidebar-guest-name">{ep.data.guest}</p>
                <p class="sidebar-guest-title">{ep.data.guestTitle}</p>
              </div>
            </div>
          </div>

          <!-- Discovery call CTA -->
          <div class="sidebar-card sidebar-card--amber">
            <h3 class="sidebar-card-heading">Want a strategy like this for your book?</h3>
            <p class="sidebar-card-body">Book a free discovery call with Cristian.</p>
            <a href="/contact" class="btn-primary" style="display:inline-flex;width:100%;justify-content:center;">
              Book a Discovery Call →
            </a>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* Header */
  .episode-header {
    background: linear-gradient(135deg, #1A1A1A 0%, #2C2C2C 100%);
    padding: 3rem 0 2.5rem;
  }

  .episode-breadcrumb { margin-bottom: 1.5rem; }

  .breadcrumb-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: #9CA3AF;
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb-link:hover { color: #E8A317; }

  .episode-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .episode-num {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #E8A317;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .episode-sep { color: #6B7280; }

  .episode-date { font-size: 0.8125rem; color: #9CA3AF; }

  .episode-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.875rem;
    line-height: 1.25;
  }

  .episode-guest-line {
    font-size: 1rem;
    color: #D1D5DB;
    margin: 0 0 1rem;
  }

  .episode-guest-title { color: #9CA3AF; font-style: italic; }

  .episode-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .episode-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #E8A317;
    background: rgba(232,163,23,0.1);
    border: 1px solid rgba(232,163,23,0.2);
    border-radius: 9999px;
    padding: 0.2rem 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Video */
  .episode-video-section {
    background: #1A1A1A;
    padding: 2rem 0 3rem;
  }

  .youtube-wrap {
    max-width: 800px;
    margin: 0 auto;
  }

  .youtube-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    cursor: pointer;
    background: #000;
  }

  .youtube-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .youtube-facade:hover .youtube-thumb { transform: scale(1.02); }

  .youtube-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.3);
    transition: background 0.2s;
  }

  .youtube-facade:hover .youtube-play { background: rgba(0,0,0,0.15); }

  .youtube-play-icon {
    width: 5rem;
    height: 5rem;
    background: rgba(232,163,23,0.95);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    padding-left: 0.25rem;
    transition: transform 0.2s;
  }

  .youtube-facade:hover .youtube-play-icon { transform: scale(1.08); }

  .youtube-facade iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Body */
  .episode-body-wrap {
    background: #fff;
    padding: 4rem 0;
  }

  .episode-body-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  /* Prose */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #374151;
  }

  .prose h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 2rem 0 1rem;
  }

  .prose h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 1.75rem 0 0.75rem;
  }

  .prose p { margin: 0 0 1.25rem; }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }

  .prose li { margin: 0.375rem 0; }

  .prose strong { color: #1A1A1A; font-weight: 600; }

  /* Sidebar */
  .episode-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 5.5rem;
  }

  .sidebar-card {
    border: 1px solid #E5E7EB;
    border-radius: 1rem;
    padding: 1.5rem;
    background: #fff;
  }

  .sidebar-card--dark {
    background: #1A1A1A;
    border-color: #1A1A1A;
  }

  .sidebar-card--amber {
    background: #FFF8E7;
    border-color: rgba(232,163,23,0.25);
  }

  .sidebar-card-heading {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.625rem;
  }

  .sidebar-card-heading--dark { color: #1A1A1A; }

  .sidebar-card-body {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #9CA3AF;
    margin: 0 0 1rem;
  }

  .sidebar-card--amber .sidebar-card-body { color: #6B7280; }

  /* Guest */
  .sidebar-guest {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .sidebar-guest-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #E8A317, #D4920F);
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sidebar-guest-img {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .sidebar-guest-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: #1A1A1A;
    margin: 0 0 0.125rem;
  }

  .sidebar-guest-title {
    font-size: 0.8125rem;
    color: #6B7280;
    margin: 0;
  }

  @media (max-width: 960px) {
    .episode-body-inner { grid-template-columns: 1fr; }
    .episode-sidebar { position: static; }
  }
</style>

<script>
  // Lazy-load YouTube: replace facade with iframe on click
  document.querySelectorAll('.youtube-facade').forEach(facade => {
    const activate = () => {
      const id = (facade as HTMLElement).dataset.videoid;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      facade.innerHTML = '';
      facade.appendChild(iframe);
    };

    facade.addEventListener('click', activate);
    facade.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') activate();
    });
  });
</script>
