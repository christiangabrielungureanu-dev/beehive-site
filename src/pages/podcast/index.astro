---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignupForm from '../../components/SignupForm.astro';
import { getCollection } from 'astro:content';

const allEpisodes = await getCollection('podcast');
const allPosts = await getCollection('blog');
const episodes = allEpisodes.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

function youtubeId(url: string): string | undefined {
  const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([A-Za-z0-9_-]{11})/);
  return m?.[1];
}

function getYoutubeId(guid: string): string | undefined {
  const post = allPosts.find(p => p.data.episodeGuids.includes(guid) && p.data.youtubeUrl);
  return post?.data.youtubeUrl ? youtubeId(post.data.youtubeUrl) : undefined;
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const podcastSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: 'The Hive Mind Podcast',
  description:
    'Conversations with authors, marketers, and operators on turning a book into a business asset — pipeline, deals, and paid stages.',
  url: new URL('/podcast/', Astro.site).href,
  webFeed: 'https://api.riverside.com/hosting/uEOr9jmt.rss',
  image: new URL('/og-abstract.png', Astro.site).href,
  author: { '@type': 'Person', name: 'Cristian Ungureanu' },
};
---

<BaseLayout
  title="The Hive Mind Podcast — Book Marketing for Experts & Founders"
  description="The Hive Mind: conversations on turning a book into a business asset. Listen on Spotify, Apple Podcasts, or YouTube. New episodes every two weeks."
>
  <script type="application/ld+json" set:html={JSON.stringify(podcastSchema)} />

  <!-- Hero -->
  <section class="podcast-hero">
    <div class="container podcast-hero-inner">
      <div class="podcast-hero-content">
        <span class="podcast-badge">
          <span class="podcast-badge-dot" aria-hidden="true"></span>
          New Episodes Every Two Weeks
        </span>
        <h1 class="podcast-hero-heading">The Hive Mind Podcast</h1>
        <p class="podcast-hero-sub">
          Real conversations with authors, marketers, and operators on turning a book into a
          business asset — pipeline, deal velocity, and the keynote circuit.
        </p>

        <div class="podcast-platforms">
          <span class="podcast-platforms-label">Listen on</span>
          <div class="podcast-platform-icons">
            <a href="https://open.spotify.com/show/033l9h1JaE3qhlslHbDS7h" target="_blank" rel="noopener" class="podcast-platform">🎙️ Spotify</a>
            <a href="https://podcasts.apple.com/podcast/id1896795747" target="_blank" rel="noopener" class="podcast-platform">🎧 Apple Podcasts</a>
            <a href="https://www.youtube.com/playlist?list=PL0Gqs3LMAOx3A4XNjP9xZNUHYOa7kh99i" target="_blank" rel="noopener" class="podcast-platform">▶️ YouTube</a>
          </div>
        </div>

        <div class="podcast-signup-wrap">
          <p class="podcast-signup-label">Get every new episode in your inbox:</p>
          <SignupForm
            source="podcast-page"
            userGroup="podcast-waitlist"
            buttonText="Subscribe →"
            placeholder="your@email.com"
            dark={true}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Episode list with inline players -->
  {episodes.length > 0 && (
    <section class="section podcast-episodes">
      <div class="container">
        <div class="podcast-episodes-header">
          <span class="eyebrow">Episodes</span>
          <h2 class="podcast-episodes-heading">All Episodes</h2>
        </div>
        <div class="podcast-episodes-list">
          {episodes.map(ep => {
            const ytId = getYoutubeId(ep.data.guid);
            return (
              <article class="podcast-episode-card" id={`ep-${ep.data.episode}`}>
                <div class="podcast-episode-info">
                  <div class="podcast-episode-meta-row">
                    <span class="podcast-episode-num">Episode {ep.data.episode}</span>
                    <span aria-hidden="true">·</span>
                    <time datetime={ep.data.publishDate.toISOString()}>{formatDate(ep.data.publishDate)}</time>
                    {ep.data.duration && (
                      <>
                        <span aria-hidden="true">·</span>
                        <span>{ep.data.duration}</span>
                      </>
                    )}
                  </div>
                  <h3 class="podcast-episode-title">{ep.data.title}</h3>
                  <p class="podcast-episode-summary">{ep.data.summary}</p>
                </div>
                {ytId ? (
                  <div class="podcast-episode-video">
                    <iframe
                      src={`https://www.youtube.com/embed/${ytId}`}
                      title={ep.data.title}
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  </div>
                ) : (
                  <audio controls preload="none" src={ep.data.audioUrl} class="podcast-episode-audio">
                    Your browser does not support the audio element.
                  </audio>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- About the show -->
  <section class="section podcast-about">
    <div class="container">
      <div class="podcast-about-header">
        <span class="eyebrow">About the Show</span>
        <h2 class="podcast-about-heading">What to Expect</h2>
      </div>
      <div class="podcast-about-grid">
        {[
          { icon: '🎯', title: 'No fluff, only tactics', desc: 'Every episode is built around one question: what actually works? Guests share real numbers, real campaigns, and real lessons.' },
          { icon: '📚', title: 'For business-minded authors', desc: 'Founders, consultants, and experts — self-published or traditional, debut or established — who want their book to drive leads, close deals, and book stages.' },
          { icon: '🔁', title: 'Frameworks that compound', desc: 'Funnel, attribution, and conversion thinking from SaaS, applied to books and the businesses behind them.' },
          { icon: '🤝', title: 'Guests who\'ve done it', desc: 'Not theorists. Authors, marketers, and operators who have turned books into pipeline, speaking deals, and premium clients.' },
        ].map(item => (
          <div class="podcast-about-card">
            <span class="podcast-about-icon">{item.icon}</span>
            <h3 class="podcast-about-title">{item.title}</h3>
            <p class="podcast-about-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom signup -->
  <section class="podcast-bottom-cta">
    <div class="container podcast-bottom-inner">
      <h2 class="podcast-bottom-heading">Never miss an episode.</h2>
      <p class="podcast-bottom-sub">Drop your email — every new episode lands straight in your inbox.</p>
      <div class="podcast-bottom-form">
        <SignupForm
          source="podcast-page-bottom"
          userGroup="podcast-waitlist"
          buttonText="Subscribe →"
          placeholder="your@email.com"
          dark={true}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
    margin-bottom: 0.625rem;
  }

  /* Hero */
  .podcast-hero {
    background: #1A1A1A;
    padding: 4rem 0;
  }

  .podcast-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .podcast-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #E8A317;
    background: rgba(232,163,23,0.1);
    border: 1px solid rgba(232,163,23,0.2);
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .podcast-badge-dot {
    width: 6px;
    height: 6px;
    background: #E8A317;
    border-radius: 50%;
    flex-shrink: 0;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .podcast-hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .podcast-hero-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #9CA3AF;
    margin: 0 0 1.75rem;
  }

  /* Platforms */
  .podcast-platforms {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .podcast-platforms-label {
    font-size: 0.8125rem;
    color: #9CA3AF;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  .podcast-platform-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .podcast-platform {
    font-size: 0.8125rem;
    color: #6B7280;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 9999px;
    padding: 0.3rem 0.75rem;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  a.podcast-platform:hover {
    color: #E8A317;
    border-color: rgba(232,163,23,0.5);
  }

  /* Hero signup */
  .podcast-signup-wrap {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 1rem;
    padding: 1.25rem;
    max-width: 460px;
  }

  .podcast-signup-label {
    font-weight: 600;
    font-size: 0.9375rem;
    color: #E5E7EB;
    margin: 0 0 0.75rem;
  }

  /* Episode list */
  .podcast-episodes { background: #FDF8F0; }

  .podcast-episodes-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .podcast-episodes-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0;
  }

  .podcast-episodes-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 820px;
    margin: 0 auto;
  }

  .podcast-episode-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 1rem;
    overflow: hidden;
    scroll-margin-top: 6rem;
  }

  .podcast-episode-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.5rem 0;
  }

  .podcast-episode-video {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .podcast-episode-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .podcast-episode-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #6B7280;
  }

  .podcast-episode-num {
    font-weight: 700;
    color: #E8A317;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .podcast-episode-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0;
    line-height: 1.35;
  }

  .podcast-episode-summary {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #4B5563;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .podcast-episode-audio {
    width: 100%;
    height: 40px;
    display: block;
    margin: 0 1.5rem 1.5rem;
    width: calc(100% - 3rem);
  }

  /* About */
  .podcast-about { background: #fff; }

  .podcast-about-header { text-align: center; margin-bottom: 3rem; }

  .podcast-about-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0;
  }

  .podcast-about-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .podcast-about-card {
    padding: 1.5rem;
    background: #FDF8F0;
    border: 1px solid rgba(232,163,23,0.15);
    border-radius: 1rem;
  }

  .podcast-about-icon { font-size: 1.75rem; display: block; margin-bottom: 0.875rem; }

  .podcast-about-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }

  .podcast-about-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #4B5563;
    margin: 0;
  }

  /* Bottom CTA */
  .podcast-bottom-cta {
    background: #1A1A1A;
    padding: 5rem 0;
    text-align: center;
  }

  .podcast-bottom-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
  }

  .podcast-bottom-sub { font-size: 1rem; color: #9CA3AF; margin: 0 0 2rem; }

  .podcast-bottom-form { max-width: 480px; margin: 0 auto; }

  @media (max-width: 1024px) {
    .podcast-about-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .podcast-about-grid { grid-template-columns: 1fr; }
  }
</style>
