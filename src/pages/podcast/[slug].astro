---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import SignupForm from '../../components/SignupForm.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('podcast');
  return episodes.map(ep => ({
    params: { slug: ep.id },
    props: { ep },
  }));
}

const { ep } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const canonical = new URL(`/podcast/${ep.id}/`, Astro.site).href;
const ogImage = ep.data.episodeImage || '/og-abstract.png';

const episodeSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastEpisode',
  name: ep.data.title,
  description: ep.data.summary,
  datePublished: ep.data.publishDate.toISOString(),
  url: canonical,
  associatedMedia: {
    '@type': 'AudioObject',
    contentUrl: ep.data.audioUrl,
    ...(ep.data.duration && { duration: ep.data.duration }),
  },
  partOfSeries: {
    '@type': 'PodcastSeries',
    name: 'The Hive Mind Podcast',
    url: new URL('/podcast/', Astro.site).href,
  },
  ...(ep.data.episodeImage && { image: ep.data.episodeImage }),
  author: {
    '@type': 'Person',
    name: 'Cristian Ungureanu',
    url: new URL('/about', Astro.site).href,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
    { '@type': 'ListItem', position: 2, name: 'Podcast', item: new URL('/podcast/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: ep.data.title, item: canonical },
  ],
};
---

<BaseLayout
  title={`${ep.data.title} — The Hive Mind Podcast`}
  description={ep.data.summary}
  ogImage={ogImage}
  canonicalURL={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(episodeSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Header -->
  <header class="ep-header">
    <div class="container ep-header-inner">
      <nav class="ep-breadcrumb" aria-label="Breadcrumb">
        <a href="/podcast" class="ep-breadcrumb-link">← All Episodes</a>
      </nav>

      <div class="ep-header-grid">
        {ep.data.episodeImage && (
          <img
            src={ep.data.episodeImage}
            alt=""
            class="ep-cover"
            width="200"
            height="200"
            loading="eager"
          />
        )}
        <div class="ep-header-content">
          <div class="ep-meta">
            <span class="ep-num">Episode {ep.data.episode}</span>
            <span aria-hidden="true">·</span>
            <time datetime={ep.data.publishDate.toISOString()}>{formatDate(ep.data.publishDate)}</time>
            {ep.data.duration && (
              <>
                <span aria-hidden="true">·</span>
                <span>{ep.data.duration}</span>
              </>
            )}
          </div>
          <h1 class="ep-title">{ep.data.title}</h1>
          {ep.data.guest && <p class="ep-guest">with <strong>{ep.data.guest}</strong></p>}

          <div class="ep-platforms">
            <span class="ep-platforms-label">Listen on</span>
            <a href="https://open.spotify.com/show/033l9h1JaE3qhlslHbDS7h" target="_blank" rel="noopener" class="ep-platform-link">Spotify</a>
            <a href="https://podcasts.apple.com/podcast/id1896795747" target="_blank" rel="noopener" class="ep-platform-link">Apple Podcasts</a>
            <a href="https://www.youtube.com/playlist?list=PL0Gqs3LMAOx3A4XNjP9xZNUHYOa7kh99i" target="_blank" rel="noopener" class="ep-platform-link">YouTube</a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Player + show notes -->
  <section class="ep-body">
    <div class="container ep-body-inner">
      <audio controls preload="none" src={ep.data.audioUrl} class="ep-audio">
        Your browser does not support the audio element.
      </audio>

      {ep.data.description && (
        <div class="ep-notes" set:html={ep.data.description} />
      )}

      <div class="ep-subscribe">
        <p class="ep-subscribe-label">Get every new episode in your inbox:</p>
        <SignupForm
          source={`podcast-ep-${ep.data.episode}`}
          userGroup="podcast-waitlist"
          buttonText="Subscribe →"
          placeholder="your@email.com"
        />
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  /* ── Header ─────────────────────────────────── */
  .ep-header {
    background: #1A1A1A;
    padding: 3rem 0 2.5rem;
  }

  .ep-breadcrumb { margin-bottom: 1.75rem; }

  .ep-breadcrumb-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: #6B7280;
    text-decoration: none;
    transition: color 0.15s;
  }

  .ep-breadcrumb-link:hover { color: #E8A317; }

  .ep-header-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    align-items: center;
  }

  .ep-cover {
    width: 200px;
    height: 200px;
    border-radius: 1rem;
    object-fit: cover;
    display: block;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .ep-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #6B7280;
    margin-bottom: 0.75rem;
  }

  .ep-num {
    font-weight: 700;
    color: #E8A317;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ep-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .ep-guest {
    font-size: 1rem;
    color: #9CA3AF;
    margin: 0 0 1.25rem;
  }

  .ep-guest strong { color: #E5E7EB; font-weight: 600; }

  .ep-platforms {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
  }

  .ep-platforms-label {
    font-size: 0.75rem;
    color: #6B7280;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  .ep-platform-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #E8A317;
    text-decoration: none;
    border: 1px solid rgba(232,163,23,0.3);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    transition: background 0.15s, border-color 0.15s;
  }

  .ep-platform-link:hover {
    background: rgba(232,163,23,0.1);
    border-color: #E8A317;
  }

  /* ── Body ────────────────────────────────────── */
  .ep-body {
    background: #fff;
    padding: 3rem 0 5rem;
  }

  .ep-body-inner { max-width: 760px; }

  .ep-audio {
    width: 100%;
    height: 48px;
    display: block;
    margin-bottom: 3rem;
    border-radius: 0.5rem;
  }

  /* Show notes — rendered from RSS HTML */
  .ep-notes {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: #374151;
    margin-bottom: 3rem;
  }

  :global(.ep-notes p) { margin: 0 0 1.25rem; }
  :global(.ep-notes a) {
    color: #C8860E;
    text-decoration: none;
    border-bottom: 1px solid rgba(200,134,14,0.35);
  }
  :global(.ep-notes a:hover) { border-bottom-color: #C8860E; }
  :global(.ep-notes ul), :global(.ep-notes ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  :global(.ep-notes li) { margin: 0.4rem 0; }
  :global(.ep-notes strong) { color: #1A1A1A; font-weight: 600; }

  /* Subscribe strip */
  .ep-subscribe {
    background: #FDF8F0;
    border: 1px solid rgba(232,163,23,0.2);
    border-radius: 1rem;
    padding: 1.75rem;
  }

  .ep-subscribe-label {
    font-weight: 600;
    font-size: 1rem;
    color: #1A1A1A;
    margin: 0 0 1rem;
  }

  /* ── Responsive ──────────────────────────────── */
  @media (max-width: 600px) {
    .ep-header-grid {
      grid-template-columns: 1fr;
    }
    .ep-cover {
      width: 140px;
      height: 140px;
    }
  }
</style>
