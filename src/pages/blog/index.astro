---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Blog — Book Marketing for Experts & Founders"
  description="Deep-dives on turning a book into a business engine — lead generation, sales velocity, speaking pipeline, and more. Built on conversations from The Hive Mind Podcast."
>
  <section class="blog-hero section">
    <div class="container blog-hero-inner">
      <span class="eyebrow">The Hive</span>
      <h1 class="blog-hero-heading">
        Field notes on<br />
        <em class="accent">books that drive business</em>
      </h1>
      <p class="blog-hero-sub">
        Deep-dives on the work that compounds — lead generation, sales velocity, the speaking circuit.
        Built on conversations with operators, authors, and marketers from The Hive Mind Podcast.
      </p>
    </div>
  </section>

  <section class="section blog-list-section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-list">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="blog-list-item">
              {post.data.coverImage && (
                <img src={post.data.coverImage} alt="" class="blog-list-cover" loading="lazy" />
              )}
              <div class="blog-list-body">
                <time class="blog-list-date" datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
                <h2 class="blog-list-title">{post.data.title}</h2>
                <p class="blog-list-desc">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="blog-empty">Articles are on the way. In the meantime, the conversations behind them are <a href="/podcast">on the podcast</a>.</p>
      )}
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
    margin-bottom: 0.625rem;
  }

  .accent { font-style: italic; color: #E8A317; }

  .blog-hero {
    background: linear-gradient(135deg, #FFFDF7 0%, #FFF8E7 100%);
    text-align: center;
  }

  .blog-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .blog-hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: #1A1A1A;
    margin: 0.5rem 0 1.25rem;
    line-height: 1.15;
  }

  .blog-hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #4B5563;
    max-width: 56ch;
    margin: 0 auto;
  }

  .blog-list-section {
    background: #fff;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 820px;
    margin: 0 auto;
  }

  .blog-list-item {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
    align-items: center;
    background: #FDF8F0;
    border: 1px solid rgba(232,163,23,0.15);
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .blog-list-item:hover {
    border-color: rgba(232,163,23,0.4);
    box-shadow: 0 8px 24px rgba(0,0,0,0.05);
  }

  .blog-list-cover {
    width: 220px;
    aspect-ratio: 16 / 9;
    border-radius: 0.625rem;
    object-fit: cover;
    object-position: left center;
    display: block;
  }

  .blog-list-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-list-date {
    font-size: 0.8125rem;
    color: #6B7280;
    font-weight: 500;
  }

  .blog-list-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0;
    line-height: 1.3;
  }

  .blog-list-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #4B5563;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-empty {
    text-align: center;
    color: #6B7280;
    font-size: 1rem;
    padding: 2rem 0;
  }

  .blog-empty a {
    color: #E8A317;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(232,163,23,0.3);
  }

  .blog-empty a:hover { border-bottom-color: #E8A317; }

  @media (max-width: 600px) {
    .blog-list-item {
      grid-template-columns: 1fr;
    }
    .blog-list-cover {
      width: 100%;
      aspect-ratio: 16 / 9;
    }
  }
</style>
