---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupForm from '../components/SignupForm.astro';
---

<BaseLayout
  title="Webinar: Book Marketing for Experts & Founders — Beehive"
  description="Free live webinar with Cristian Ungureanu on how experts and founders can turn a book into a real business engine — pipeline, sales velocity, and paid stages."
>
  <!-- Hero -->
  <section class="webinar-hero">
    <div class="container webinar-hero-inner">
      <div class="webinar-hero-content">
        <span class="webinar-live-badge">
          <span class="webinar-live-dot" aria-hidden="true"></span>
          Free Live Webinar
        </span>
        <h1 class="webinar-heading">
          How to Build a Book Marketing Engine<br />
          <em class="webinar-accent">That Actually Sells</em>
        </h1>
        <p class="webinar-sub">
          A free, live deep-dive into the book marketing system Cristian used to help
          generate over $5M in ARR for tech companies — adapted specifically for authors.
          Walk away with a clear roadmap you can act on immediately.
        </p>

        <!-- What you'll learn -->
        <ul class="webinar-learns">
          {[
            'The 4-part book marketing framework (positioning → audience → launch → scale)',
            'How to build your email list before your book is even finished',
            'The podcast guesting strategy that turns listeners into buyers',
            'Amazon and metadata optimization: what actually moves the needle',
          ].map(item => (
            <li class="webinar-learn-item">
              <span class="webinar-learn-check" aria-hidden="true">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Signup card -->
      <div class="webinar-signup-card">
        <div class="webinar-signup-header">
          <h2 class="webinar-signup-title">Reserve Your Spot</h2>
          <p class="webinar-signup-meta">Free • Live • Limited seats</p>
        </div>

        <SignupForm
          source="webinar-signup"
          userGroup="webinar"
          buttonText="Save My Spot →"
          placeholder="your@email.com"
          showName={true}
          showBookTitle={true}
        />

        <div class="webinar-signup-notes">
          <p>✓ You'll receive the date & time by email</p>
          <p>✓ Can't make it live? We'll send the replay</p>
          <p>✓ No spam, ever. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Host section -->
  <section class="section webinar-host">
    <div class="container webinar-host-inner">
      <div class="webinar-host-photo">
        <img src="/cristian-pic.jpg" alt="Cristian Ungureanu, founder of Beehive Book Marketing" class="host-photo-img" />
      </div>
      <div class="webinar-host-content">
        <span class="eyebrow">Your Host</span>
        <h2 class="webinar-host-name">
          <span class="host-name-script">Cristian Ungureanu</span>
        </h2>
        <p class="webinar-host-title">Founder, Beehive Book Marketing</p>
        <p class="webinar-host-bio">
          Cristian is a senior growth marketer who spent over a decade building marketing systems
          for B2B SaaS companies — including QuickMail.io and ScraperAPI.com, where he helped
          generate over $5M in ARR. He founded Beehive Book Marketing to bring those same
          growth principles to authors and publishers.
        </p>
        <div class="webinar-host-creds">
          <span class="host-cred">QuickMail.io</span>
          <span class="host-cred-sep">·</span>
          <span class="host-cred">ScraperAPI.com</span>
          <span class="host-cred-sep">·</span>
          <span class="host-cred">$5M+ ARR</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="section webinar-proof">
    <div class="container webinar-proof-inner">
      <h2 class="webinar-proof-heading">What Attendees Will Leave With</h2>
      <div class="webinar-proof-grid">
        {[
          { icon: '📋', title: 'A clear 90-day roadmap', desc: 'Know exactly what to do in the first 90 days after the webinar — not just theory.' },
          { icon: '📧', title: 'An email list strategy', desc: 'The exact framework for building an email list that converts readers into buyers.' },
          { icon: '🎙️', title: 'A pitch-ready podcast outreach template', desc: 'Walk away with a podcast guesting pitch template with a 40% response rate.' },
          { icon: '📊', title: 'Honest answers to your questions', desc: 'Live Q&A — ask the specific questions holding back your book marketing.' },
        ].map(item => (
          <div class="webinar-proof-card">
            <span class="webinar-proof-icon">{item.icon}</span>
            <h3 class="webinar-proof-title">{item.title}</h3>
            <p class="webinar-proof-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="webinar-bottom-cta">
    <div class="container webinar-bottom-inner">
      <h2 class="webinar-bottom-heading">
        Ready to stop guessing and start <em>growing?</em>
      </h2>
      <p class="webinar-bottom-sub">Join the next live session — free, no fluff, actionable from minute one.</p>
      <div class="webinar-bottom-form">
        <SignupForm
          source="webinar-signup-bottom"
          userGroup="webinar"
          buttonText="Save My Spot →"
          placeholder="your@email.com"
          dark={true}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #E8A317;
    margin-bottom: 0.625rem;
  }

  /* Hero */
  .webinar-hero {
    background: linear-gradient(135deg, #1A1A1A 0%, #2C2C2C 100%);
    padding: 5rem 0;
  }

  .webinar-hero-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 4rem;
    align-items: start;
  }

  .webinar-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #E8A317;
    background: rgba(232,163,23,0.1);
    border: 1px solid rgba(232,163,23,0.25);
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .webinar-live-dot {
    width: 6px;
    height: 6px;
    background: #E8A317;
    border-radius: 50%;
    animation: pulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .webinar-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin: 0 0 1.25rem;
  }

  .webinar-accent { font-style: italic; color: #E8A317; }

  .webinar-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #9CA3AF;
    margin: 0 0 2rem;
  }

  /* Learns */
  .webinar-learns {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .webinar-learn-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: #D1D5DB;
  }

  .webinar-learn-check {
    color: #E8A317;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  /* Signup card */
  .webinar-signup-card {
    background: #fff;
    border-radius: 1.25rem;
    padding: 2rem;
    box-shadow: 0 16px 48px rgba(0,0,0,0.25);
  }

  .webinar-signup-header { margin-bottom: 1.5rem; }

  .webinar-signup-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.25rem;
  }

  .webinar-signup-meta {
    font-size: 0.875rem;
    color: #9CA3AF;
    margin: 0;
  }

  .webinar-signup-notes {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .webinar-signup-notes p {
    font-size: 0.8125rem;
    color: #6B7280;
    margin: 0;
  }

  /* Host */
  .webinar-host { background: #fff; }

  .webinar-host-inner {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .host-photo-placeholder {
    aspect-ratio: 1;
    border-radius: 1.25rem;
    background: linear-gradient(145deg, #E8A317 0%, #F4C557 50%, #D4920F 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .host-initials {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 700;
    color: rgba(255,255,255,0.6);
  }

  .host-photo-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 1.25rem;
    display: block;
  }

  .host-name-script {
    font-family: var(--font-script);
    font-size: 2rem;
    color: #1A1A1A;
    display: block;
  }

  .webinar-host-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #E8A317;
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .webinar-host-bio {
    font-size: 1rem;
    line-height: 1.75;
    color: #374151;
    margin: 0 0 1.25rem;
  }

  .webinar-host-creds {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .host-cred {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #6B7280;
  }

  .host-cred-sep { color: #D1D5DB; }

  /* Proof */
  .webinar-proof { background: #FDF8F0; }

  .webinar-proof-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #1A1A1A;
    text-align: center;
    margin: 0 0 2.5rem;
  }

  .webinar-proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .webinar-proof-card {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .webinar-proof-icon { font-size: 1.75rem; display: block; margin-bottom: 0.875rem; }

  .webinar-proof-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }

  .webinar-proof-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #6B7280;
    margin: 0;
  }

  /* Bottom CTA */
  .webinar-bottom-cta {
    background: #1A1A1A;
    padding: 5rem 0;
    text-align: center;
  }

  .webinar-bottom-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
  }

  .webinar-bottom-heading em { font-style: italic; color: #E8A317; }

  .webinar-bottom-sub {
    font-size: 1rem;
    color: #9CA3AF;
    margin: 0 0 2rem;
  }

  .webinar-bottom-form {
    max-width: 480px;
    margin: 0 auto;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .webinar-hero-inner { grid-template-columns: 1fr; }
    .webinar-host-inner { grid-template-columns: 1fr; }
    .webinar-proof-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .webinar-proof-grid { grid-template-columns: 1fr; }
  }
</style>
